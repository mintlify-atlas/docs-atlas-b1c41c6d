  "keyFeatures": [
    "Context-aware access control with YAML policies",
    "Resource, derived role, and principal policies",
    "High-performance Policy Decision Point (PDP)",
    "Kubernetes, Lambda, and systemd deployment",
    "Multiple storage backends (disk, S3, Git, databases)",
    "Admin API for policy management",
    "Query planning for efficient database queries",
    "Comprehensive audit logging"
  ],
  "publicApiSurface": [
    "CheckResources - Check principal permissions for resources",
    "PlanResources - Generate query plans for resource access",
    "ServerInfo - Get PDP server information",
    "AddOrUpdatePolicy - Manage policies via Admin API",
    "ListPolicies - List all policies",
    "GetPolicy - Retrieve specific policy",
    "DeletePolicy - Remove policy",
    "DisablePolicy/EnablePolicy - Toggle policy state",
    "AddOrUpdateSchema - Manage attribute schemas",
    "ListAuditLogEntries - Access audit logs",
    "cerbos server - Start the PDP server",
    "cerbos compile - Compile and validate policies",
    "cerbosctl get - Retrieve policies and schemas",
    "cerbosctl put - Upload policies and schemas",
    "cerbosctl decisions - Check authorization decisions"
  ]
}
